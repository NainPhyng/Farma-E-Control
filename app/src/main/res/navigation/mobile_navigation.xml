        tools:layout="@layout/fragment_registro_sesion"
        android:label="@string/title_registosesion"
            android:name="com.example.farmae_control.ui.registosesion.RegistroSesionFragment"
            android:id="@+id/registroSesionFragment"
            />

    <fragment
        android:id="@+id/categoriaFragment"
        android:name="com.example.farmae_control.ui.categoria.CategoriaFragment"
        tools:layout="@layout/fragment_categoria"
        android:label="@string/title_categoria"
        />

    <fragment
        android:id="@+id/editarCuentaFragment"
        android:name="com.example.farmae_control.ui.cuenta.EditarCuentaFragment"
        tools:layout="@layout/fragment_editar_cuenta"
        android:label="@string/title_editarcuenta"
        />
    <fragment
        android:id="@+id/productosFragment"
        android:name="com.example.farmae_control.ui.productos.ProductosFragment"
        tools:layout="@layout/fragment_productos"
        android:label="@string/title_productos"/>

