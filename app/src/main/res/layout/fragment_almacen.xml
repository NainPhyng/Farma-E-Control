<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f1f5f9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_almacen"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvAlmacenAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_avatar_almacen"
                android:gravity="center"
                android:text="AL"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_almacen"
                    android:text="ALMACÉN"
                    android:textColor="#99f6e4"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/tvAlmacenNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal de Almacén"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnNotifAlmacen"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_notifications"
                android:tint="#FFFFFF"
                android:padding="8dp"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kpi"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvKpiTotalProductos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Productos"
                        android:textColor="#FFFFFFB3"
                        android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kpi"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="8dp">

                    <TextView android:id="@+id/tvKpiStockTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unidades"
                        android:textColor="#FFFFFFB3"
                        android:textSize="10sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kpi"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tvKpiPorVencer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#f87171"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Por vencer"
                        android:textColor="#FFFFFFB3"
                        android:textSize="10sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_kpi"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tvKpiStockBajo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#fbbf24"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock bajo"
                        android:textColor="#FFFFFFB3"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#042f2e"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/tabInventario"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tab_teal_selected"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_inventory"
                    android:tint="#2dd4bf"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inventario"
                    android:textColor="#2dd4bf"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/tabAgregarProducto"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tab"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginStart="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_add_box"
                    android:tint="#64748b"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Agregar"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabEntradasSalidas"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tab"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginStart="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_swap"
                    android:tint="#64748b"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entradas/Salidas"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabCerrarSesionAlmacen"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tab"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:layout_marginStart="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_logout"
                    android:tint="#64748b"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salir"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etBuscarProducto"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_search"
                android:hint="🔍  Buscar producto..."
                android:hintTextColor="#94a3b8"
                android:textColor="#1e293b"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="14dp"/>

            <!-- Stock actual -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Inventario — Stock actual"
                    android:textColor="#1e293b"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver todo"
                    android:textColor="#0d9488"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="14dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerInventario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </androidx.cardview.widget.CardView>


            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próximos a caducar"
                android:textColor="#1e293b"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="14dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/productoscaducados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </androidx.cardview.widget.CardView>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerPorVencer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
