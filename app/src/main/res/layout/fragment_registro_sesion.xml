<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a1628">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- LOGO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_logo_icon"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_cross"
                    android:tint="#FFFFFF"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FarmaE-Control"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:layout_gravity="center_horizontal"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crea tu cuenta para comenzar"
                android:textColor="#a8d4f5"
                android:textSize="12sp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- STEP LABEL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASO 1 DE 2 — SELECCIONA TU ROL"
            android:textColor="#5aa7e8"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"/>

        <!-- ROLE CARDS GRID -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:layout_marginBottom="16dp">

            <!-- Cliente -->
            <LinearLayout
                android:id="@+id/cardCliente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_role_card_selected"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_role_icon_cliente"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person"
                        android:tint="#1d4ed8"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compra productos y sigue tus pedidos"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Almacén -->
            <LinearLayout
                android:id="@+id/cardAlmacen"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_role_card"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_role_icon_almacen"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_store"
                        android:tint="#065f46"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Almacen"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gestiona inventario y despachos"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Doctor -->
            <LinearLayout
                android:id="@+id/cardDoctor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_role_card"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_role_icon_doctor"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_heart_pulse"
                        android:tint="#9d174d"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Doctor"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Atiende pacientes y gestiona citas"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Admin (deshabilitado) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_role_card"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp"
                android:alpha="0.55">
                <LinearLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_role_icon_admin"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_shield"
                        android:tint="#5b21b6"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solo por autorización interna"
                    android:textColor="#f87171"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </GridLayout>

        <!-- FORM CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nombre + Apellido -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOMBRE"
                        android:textColor="#a8d4f5"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etNuevoNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="11dp"
                        android:hint="Nombre"
                        android:hintTextColor="#64748b"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:inputType="textPersonName"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="APELLIDO"
                        android:textColor="#a8d4f5"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etApellido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="11dp"
                        android:hint="Apellido"
                        android:hintTextColor="#64748b"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:inputType="textPersonName"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORREO ELECTRÓNICO"
                android:textColor="#a8d4f5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etNuevoCorreo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="11dp"
                android:hint="correo@ejemplo.com"
                android:hintTextColor="#64748b"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:inputType="textWebEmailAddress"
                android:layout_marginBottom="12dp"/>

            <!-- Teléfono -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELÉFONO"
                android:textColor="#a8d4f5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="11dp"
                android:hint="+52 55 1234 5678"
                android:hintTextColor="#64748b"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:inputType="phone"
                android:layout_marginBottom="12dp"/>

            <!-- Dirección -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIRECCIÓN"
                android:textColor="#a8d4f5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etNuevaDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="11dp"
                android:hint="Calle, número, ciudad"
                android:hintTextColor="#64748b"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <!-- Edad + Usuario -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EDAD"
                        android:textColor="#a8d4f5"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etEdad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="11dp"
                        android:hint="Edad"
                        android:hintTextColor="#64748b"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:inputType="number"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USUARIO"
                        android:textColor="#a8d4f5"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etNuevoUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input"
                        android:padding="11dp"
                        android:hint="@usuario"
                        android:hintTextColor="#64748b"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Contraseña -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTRASEÑA"
                android:textColor="#a8d4f5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>
            <EditText
                android:id="@+id/etNuevaContraseña"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="11dp"
                android:hint="••••••••"
                android:hintTextColor="#64748b"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:inputType="textPassword"
                android:layout_marginBottom="12dp"/>

            <!-- Campo cédula (solo Doctor) -->
            <LinearLayout
                android:id="@+id/layoutCedula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CÉDULA PROFESIONAL"
                    android:textColor="#a8d4f5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etCedula"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_input"
                    android:padding="11dp"
                    android:hint="7-8 dígitos"
                    android:hintTextColor="#64748b"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:inputType="number"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠ Tu cédula será validada. Un administrador aprobará tu cuenta."
                    android:textColor="#d97706"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>
            </LinearLayout>

            <!-- Botón registrar -->
            <Button
                android:id="@+id/btnCrearCuenta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_primary"
                android:text="Continuar"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Términos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes cuenta?"
            android:textColor="#a8d4f5"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:text="Iniciar sesión"
            android:textColor="#38bdf8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
