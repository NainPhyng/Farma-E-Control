<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:map="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.sucursales.SucursalesFragment">

    <TextView
        android:id="@+id/textView"
        android:layout_width="183dp"
        android:layout_height="51dp"
        android:layout_marginBottom="72dp"
        android:text="Farmacias JGAMA"
        android:textColor="@color/azultitulos"
        android:textSize="20sp"
        android:textStyle="bold"
        map:layout_constraintBottom_toTopOf="@+id/maps"
        map:layout_constraintEnd_toEndOf="parent"
        map:layout_constraintStart_toStartOf="parent"
        map:layout_constraintTop_toTopOf="parent" />

    <fragment
        android:id="@+id/maps"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="246dp"
        android:layout_height="334dp"
        map:cameraZoom="10"
        map:layout_constraintBottom_toBottomOf="parent"
        map:layout_constraintEnd_toEndOf="parent"
        map:layout_constraintStart_toStartOf="parent"
        map:layout_constraintTop_toTopOf="parent"
        map:uiRotateGestures="true"
        map:uiScrollGestures="true"
        map:uiZoomControls="true"
        map:uiZoomGestures="true" />

    <TextView
        android:layout_width="276dp"
        android:layout_height="74dp"
        android:layout_marginStart="4dp"
        android:text="Presiona la sucursal y depues el mapa, para saber que tan lejos queda de ti :D"
        map:layout_constraintBottom_toBottomOf="parent"
        map:layout_constraintEnd_toEndOf="parent"
        map:layout_constraintHorizontal_bias="0.48"
        map:layout_constraintStart_toStartOf="parent"
        map:layout_constraintTop_toTopOf="parent"
        map:layout_constraintVertical_bias="0.861" />

</androidx.constraintlayout.widget.ConstraintLayout>
